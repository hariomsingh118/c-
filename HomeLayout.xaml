<Window x:Class="Data_Sanitization.HomeLayout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Disk Management Tool" Height="850" Width="1350"
        WindowStartupLocation="CenterScreen" Background="#F4F7F9">

    <Window.Resources>
        <SolidColorBrush x:Key="TealMain"  Color="#00A99D"/>
        <SolidColorBrush x:Key="BgLight"   Color="#F4F7F9"/>
        <SolidColorBrush x:Key="CardWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TxtDark"   Color="#1F2937"/>
        <SolidColorBrush x:Key="TxtGrey"   Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderClr" Color="#E5E7EB"/>

        <!-- Card Shadow Style -->
        <Style x:Key="SoftCard" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Style -->
        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Foreground"              Value="#6B7280"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Padding"                 Value="15,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBF5F4"/>
                                <Setter Property="Foreground" Value="#00A99D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Margin="25,30,25,30" HorizontalAlignment="Left">
                    <Image Source="Assets/Logo.png" Height="90" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Nav Menu -->
                <StackPanel Grid.Row="1" Margin="12,0">

                    <!-- ACTIVE: Home/Dashboard -->
                    <Button Style="{StaticResource SideBtn}" Background="#EBF5F4"
                            Foreground="#00A99D" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2302;" FontSize="16" Margin="0,0,10,0"
                                       Foreground="#00A99D" VerticalAlignment="Center"/>
                            <TextBlock Text="Home" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SideBtn}" Margin="0,4" Click="NavSanitize_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F6E1;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sanitize Drive" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4BE;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Drive Manager" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Margin="0,4" Click="NavReports_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2750;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2713;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Verification" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- System Status Widget -->
                <Border Grid.Row="2" Margin="15,20" Background="#F9FAFB" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="System Status" Foreground="#6B7280" FontSize="10" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="All Systems Operational" Foreground="#10B981" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="Last Check: 2 mins ago" Foreground="#9CA3AF" FontSize="10" Margin="0,3,0,2"/>
                        <TextBlock Text="Version: 2.1.0" Foreground="#9CA3AF" FontSize="10"/>
                        <Separator Background="#E5E7EB" Margin="0,12"/>
                        <Border Background="#00A99D" CornerRadius="6" Padding="10,7">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F512;" FontSize="11" Margin="0,0,6,0"/>
                                <TextBlock Text="Secure &amp; Verified" Foreground="White"
                                           FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 2. MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="0,0,0,1" Padding="40,0">
                <Grid VerticalAlignment="Center">
                    <Border Background="#F3F4F6" Width="320" Height="40" CornerRadius="12"
                            HorizontalAlignment="Left" BorderThickness="1" BorderBrush="#E5E7EB">
                        <Grid Margin="15,0">
                            <TextBlock Text="Search analytics or reports..." VerticalAlignment="Center"
                                       Foreground="#9CA3AF" FontSize="12"/>
                            <TextBlock Text="&#x1F50D;" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="White" Width="40" Height="40" CornerRadius="10"
                                Margin="0,0,10,0" BorderThickness="1" BorderBrush="#E5E7EB">
                            <TextBlock Text="&#x1F4CA;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="White" Width="40" Height="40" CornerRadius="10"
                                Margin="0,0,10,0" BorderThickness="1" BorderBrush="#E5E7EB">
                            <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" FontWeight="Bold" Foreground="#374151"/>
                        </Border>
                        <Border Background="White" Width="40" Height="40" CornerRadius="10"
                                BorderThickness="1" BorderBrush="#E5E7EB">
                            <TextBlock Text="&#x1F511;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dashboard Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <Grid Margin="40,10,40,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Welcome + Hero Card -->
                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Hello Admin," Foreground="#6B7280" FontSize="18" FontWeight="Light"/>
                        <TextBlock Text="Data Sanitization Center" Foreground="#1F2937"
                                   FontSize="32" FontWeight="Black" Margin="0,-5,0,0"/>

                        <Border Style="{StaticResource SoftCard}" Height="180" Margin="0,25,20,0">
                            <Grid Margin="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#E6F7F5" Width="100" Height="100" CornerRadius="20">
                                    <Path Data="M5,13 L9,17 L19,7" Stroke="#00A99D" StrokeThickness="4"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Width="30" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="30,0,0,0">
                                    <TextBlock Text="Ready to Sanitize?" Foreground="#1F2937"
                                               FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Choose a sector or drive to begin a permanent wipe."
                                               Foreground="#6B7280" FontSize="13" Margin="0,5,0,20"/>
                                    <Button Background="#00A99D" Foreground="White"
                                            Content="Initialize Erasure  →" FontWeight="Bold"
                                            Padding="25,12" HorizontalAlignment="Left"
                                            BorderThickness="0" Click="NavSanitize_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Right Stats Column -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,65,0,0">
                        <TextBlock Text="Drives &amp; Intelligence" Foreground="#1F2937"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Border Style="{StaticResource SoftCard}" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Active Drives" FontSize="11"
                                           Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBlock Text="4 Units Connected" FontSize="18"
                                           FontWeight="Black" Foreground="#1F2937" Margin="0,5,0,0"/>
                                <ProgressBar Value="75" Height="6" Margin="0,15,0,0"
                                             Foreground="#00A99D" Background="#F3F4F6" BorderThickness="0"/>
                                <TextBlock Text="75% Sanitization Verified" FontSize="10"
                                           Foreground="#6B7280" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SoftCard}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Recent Reports" FontSize="11"
                                           Foreground="#6B7280" FontWeight="Bold"/>
                                <TextBlock Text="6 Completed" FontSize="18"
                                           FontWeight="Black" Foreground="#1F2937" Margin="0,5,0,0"/>
                                <TextBlock Text="View All →" FontSize="11" Foreground="#00A99D"
                                           FontWeight="SemiBold" Margin="0,10,0,0" Cursor="Hand"
                                           MouseLeftButtonDown="NavReportsText_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Methods Row -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,40,0,0">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Secure Sanitization Methods" Foreground="#1F2937"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="View All Methods →" Foreground="#00A99D" FontSize="12"
                                       FontWeight="SemiBold" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Cursor="Hand"
                                       MouseLeftButtonDown="NavSanitizeText_Click"/>
                        </Grid>
                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource SoftCard}" Padding="25" Margin="0,0,20,0">
                                <StackPanel>
                                    <Border Background="#E6F7F5" Width="40" Height="40"
                                            CornerRadius="8" HorizontalAlignment="Left" Margin="0,0,0,15">
                                        <TextBlock Text="&#x1F3DB;" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="NIST 800-88" FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock Text="Government standard purge for high-density SSDs."
                                               Foreground="#6B7280" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SoftCard}" Padding="25" Margin="0,0,20,0">
                                <StackPanel>
                                    <Border Background="#EFF6FF" Width="40" Height="40"
                                            CornerRadius="8" HorizontalAlignment="Left" Margin="0,0,0,15">
                                        <TextBlock Text="&#x1F6E1;" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="DoD 3-Pass" FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock Text="Three-pass military grade overwrite with verification."
                                               Foreground="#6B7280" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SoftCard}" Padding="25">
                                <StackPanel>
                                    <Border Background="#1F2937" Width="40" Height="40"
                                            CornerRadius="8" HorizontalAlignment="Left" Margin="0,0,0,15">
                                        <TextBlock Text="&#x2022;&#x2022;&#x2022;" FontSize="14" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Gutmann" FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock Text="35-pass ultra-secure forensic level sanitization."
                                               Foreground="#6B7280" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,40,0,0"
                            Padding="0,16,0,0" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock Text="&#x1F512; Data Sanitization All Rights Reserved 2025"
                                       Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ISO 27001" Foreground="#6B7280" FontSize="10"
                                           FontWeight="Bold" Margin="0,0,18,0" VerticalAlignment="Center"/>
                                <TextBlock Text="NIST" Foreground="#6B7280" FontSize="10"
                                           FontWeight="Bold" Margin="0,0,18,0" VerticalAlignment="Center"/>
                                <TextBlock Text="DoD DSS" Foreground="#6B7280" FontSize="10"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
